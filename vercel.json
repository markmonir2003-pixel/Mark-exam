{
    "routes": [
        {
            "src": "/_next/(.*)",
            "headers": {
                "cache-control": "s-maxage=31536000, immutable"
            },
            "continue": true
        },
        {
            "src": "/fonts/(.*)",
            "headers": {
                "cache-control": "s-maxage=31536000, immutable"
            },
            "continue": true
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}